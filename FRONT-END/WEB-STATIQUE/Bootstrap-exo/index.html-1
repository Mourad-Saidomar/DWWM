<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    
    <title>Bootstrap</title>
</head>
<body class="bg-dark">
    <header>
        <div class="container-fluid">
            <div class="row">
                <div class="col-4 border bg-primary text-white text-center p-4">LOGO</div>
                <div class="col-8 border bg-primary text-white text-center p-4">BANNER</div>                
            </div>
            <div class="row">
                <div class="col-12 border bg-primary text-white text-center p-2">HEADER LINK</div>                
            </div>
        </div>
    </header>
    <main>
        <div class="container-fluid">
            <div class="row vh-100">
                <div class="col-3 border bg-white text-dark d-flex align-items-center justify-content-center">LEFT</div>
                <div class="col-6 border bg-white text-dark d-flex align-items-center justify-content-center">CONTENT</div>                
                <div class="col-3 border bg-white text-dark d-flex align-items-center justify-content-center">RIGHT</div>
            </div>
        </div>
        

    </main>
    <footer>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12 border bg-danger text-white text-center p-4">FOOTER</div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>